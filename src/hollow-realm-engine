const cons = […(p.consequences||[]), {type, label}];
updatePlayer(id, {consequences: cons});
addLog({type:“consequence”, who:p.charname, what:`Gained: ${label}`});
};

const rmConsequence = (id, idx) => {
const p = players.find(x => x.id === id);
if (!p) return;
const label = p.consequences[idx]?.label;
updatePlayer(id, {consequences: p.consequences.filter((_,i)=>i!==idx)});
addLog({type:“consequence”, who:p.charname, what:`Cleared: ${label}`});
};

/* ────────────────────────────────────────────────
INVENTORY
──────────────────────────────────────────────── */
const addItem = (id) => {
if (!addItemForm.name.trim()) return;
const p = players.find(x => x.id === id);
if (!p) return;
const item = {…addItemForm, name:addItemForm.name.trim()};
updatePlayer(id, {inventory: […(p.inventory||[]), item]});
addLog({type:“item”, who:p.charname, what:`Obtained: ${item.name}`});
setAddItemForm({name:””,type:“weapon”,rarity:“Common”,condition:“Pristine”,note:””});
setAddItemTarget(null);
};

const rmItem = (playerId, idx) => {
const p = players.find(x => x.id === playerId);
if (!p) return;
const item = p.inventory[idx];
updatePlayer(playerId, {inventory: p.inventory.filter((_,i)=>i!==idx)});
addLog({type:“item”, who:p.charname, what:`Lost: ${item?.name||"item"}`});
};

const toggleEquip = (playerId, idx) => {
const p = players.find(x => x.id === playerId);
if (!p) return;
const inv = p.inventory.map((item, i) => ({…item, equipped: i===idx ? !item.equipped : (item.type===p.inventory[idx].type ? false : item.equipped)}));
updatePlayer(playerId, {inventory: inv});
};

/* ────────────────────────────────────────────────
COMPANION
──────────────────────────────────────────────── */
const assignCompanion = (id, type) => {
const cData = COMPANION_TYPES[type];
updatePlayer(id, {companion:{type, hp:cData.hp, maxHp:cData.hp, status:“active”}});
addLog({type:“gift”, who:players.find(p=>p.id===id)?.charname||”?”, what:`Bonded companion: ${cData.icon} ${type}`});
};

const adjCompHp = (id, delta) => {
const p = players.find(x => x.id === id);
if (!p?.companion) return;
const hp = clamp(p.companion.hp + delta, 0, p.companion.maxHp);
const status = hp <= 0 ? “fled” : “active”;
updatePlayer(id, {companion:{…p.companion, hp, status}});
if (hp <= 0) addLog({type:“hp”, who:p.charname, what:`Companion ${p.companion.type} fled to HQ at 0 HP.`});
};

