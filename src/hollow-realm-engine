const upgradeRoom = (room) => {
const cur = baseRooms[room] || 0;
const tiers = BASE_ROOMS[room]?.tiers;
if (!tiers || cur >= tiers.length) return;
const cost = tiers[cur]?.cost;
if (!window.confirm(`Upgrade ${BASE_ROOMS[room].name} to Level ${cur+1}? Cost: ${cost?.toLocaleString() || 0} coins`)) return;
setBaseRooms(prev => ({…prev, [room]: cur+1}));
addLog({type:“gift”, who:“HQ”, what:`${BASE_ROOMS[room].name} upgraded to Level ${cur+1}.`});
};

const addResident = () => {
