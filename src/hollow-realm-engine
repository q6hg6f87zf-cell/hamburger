const esc = (s) => String(s || “”).replace(/[<>&”]/g, c => ({”<”:”<”,”>”:”>”,”&”:”&”,’”’:”"”}[c]));
const d20 = () => Math.floor(Math.random() * 20) + 1;
const clamp = (v, min, max) => Math.min(max, Math.max(min, v));
const rangeLabel = (r) => r[0] === r[1] ? String(r[0]) : r[0] + “–” + r[1];

function getDiceDisplay(r) {
if (!r) return null;
if (r === 1) return {label:“💀 FUMBLE”,desc:“Catastrophic backfire.”,bg:”#2a0505”,glow:”#ef5350”};
if (r <= 4) return {label:“✗ FAIL”,desc:“Action fails entirely.”,bg:”#1a0505”,glow:”#ef5350”};
if (r <= 9) return {label:“⚠ WEAK HIT”,desc:“Partial — something goes wrong.”,bg:”#1a0e00”,glow:”#ff9800”};
if (r <= 14) return {label:“✓ SUCCESS”,desc:“Clean success.”,bg:”#041a06”,glow:”#4caf50”};
if (r <= 19) return {label:“★ STRONG HIT”,desc:“Success + bonus effect.”,bg:”#021020”,glow:”#4fc3f7”};
return {label:“⚡ CRITICAL!”,desc:“LEGENDARY. ANNOUNCE IT.”,bg:”#160520”,glow:”#ce93d8”};
}

function getPlayerStats(p) {
const base = CLASS_BASE_STATS[p.cls] || {STR:5,DEF:5,INT:5,WIS:5,SPD:5,CHA:5,LCK:5};
const trait = TRAIT_TIERS.find(t => t.level === p.traitLevel);
const traitBonus = trait ? trait.bonus : 0;
const raceStats = p.race && RACES[p.race] ? RACES[p.race].stats : {STR:0,DEF:0,INT:0,WIS:0,SPD:0,CHA:0,LCK:0};
const primary = PRIMARY_STAT[p.cls] || “STR”;
const companion = p.companion && COMPANION_TYPES[p.companion.type];
let finalStats = {};
for (const s in base) {
let v = base[s] + raceStats[s] + (s === primary ? traitBonus : 0);
if (companion && companion.statBuff && companion.statBuff[s] && p.companion.status === “active”) v += companion.statBuff[s];
if (p.isHoF && s === “CHA”) v += 3;
finalStats[s] = (p.statOverrides && p.statOverrides[s] !== undefined) ? p.statOverrides[s] : v;
}
return finalStats;
}

