const shop = {bargain:{name:pick(LEDGER_POOLS.bargain),price:500},essential:{name:pick(LEDGER_POOLS.essential),price:2000},artifact:{name:pick(LEDGER_POOLS.artifact),price:8000},rolledAt:new Date().toLocaleDateString()};
setDailyShop(shop);
