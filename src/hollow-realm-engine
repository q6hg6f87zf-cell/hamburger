const LOC_3D = {
hq:      { pos: [0, 0, 0],       color: 0xffd54f, emissive: 0xffa000, size: 0.25 },
forest:  { pos: [-3.2, 0, -2],   color: 0x2e7d32, emissive: 0x1b5e20, size: 0.2  },
kingdom: { pos: [0.3, 0, -3],    color: 0xc62828, emissive: 0x7f0000, size: 0.2  },
caverns: { pos: [-1.4, -0.5, 2], color: 0x6a1b9a, emissive: 0x4a148c, size: 0.2  },
edge:    { pos: [2.8, 0, -0.5],  color: 0x9c27b0, emissive: 0x6a0080, size: 0.22 },
library: { pos: [2.0, -0.3, 2.2],color: 0x1565c0, emissive: 0x0d47a1, size: 0.2  },
};

function TerrainPlane() {
const meshRef = useRef();
const geom = useMemo(() => {
const g = new THREE.PlaneGeometry(10, 10, 40, 40);
const pos = g.attributes.position;
for (let i = 0; i < pos.count; i++) {
const x = pos.getX(i), z = pos.getY(i);
const h = (Math.sin(x * 0.8) * 0.25 + Math.cos(z * 0.6) * 0.2 + Math.sin((x + z) * 0.5) * 0.15) * 0.5;
pos.setZ(i, h);
}
g.computeVertexNormals();
return g;
}, []);

return (
<mesh ref={meshRef} geometry={geom} rotation={[-Math.PI / 2, 0, 0]} position={[0, -0.6, 0]}>
<meshLambertMaterial color={0x1a0e04} wireframe={false} />
</mesh>
);
}

function GridLines() {
const points = [];
for (let i = -5; i <= 5; i++) {
points.push(new THREE.Vector3(-5, -0.58, i), new THREE.Vector3(5, -0.58, i));
points.push(new THREE.Vector3(i, -0.58, -5), new THREE.Vector3(i, -0.58, 5));
}
const geom = new THREE.BufferGeometry().setFromPoints(points);
return <lineSegments geometry={geom}><lineBasicMaterial color={0x3d1e08} transparent opacity={0.4} /></lineSegments>;
}

function ConnectionLine({ fromPos, toPos }) {
const points = [new THREE.Vector3(…fromPos), new THREE.Vector3(…toPos)];
const geom = new THREE.BufferGeometry().setFromPoints(points);
return <lineSegments geometry={geom}><lineBasicMaterial color={0xc8813a} transparent opacity={0.25} linewidth={1} /></lineSegments>;
}

function LocationNode({ locId, data, danger, selected, onSelect, hasPlayer }) {
const meshRef = useRef();
const glowRef = useRef();
const [hovered, setHovered] = useState(false);
const dangerColor = [0x66bb6a, 0x66bb6a, 0x81c784, 0xff9800, 0xef5350, 0xb71c1c][danger] || 0xffffff;

useFrame((state) => {
if (!meshRef.current) return;
const t = state.clock.elapsedTime;
meshRef.current.position.y = data.pos[1] + Math.sin(t * 1.2 + data.pos[0]) * 0.04;
if (selected) meshRef.current.rotation.y = t * 0.8;
if (glowRef.current) {
glowRef.current.material.opacity = 0.15 + Math.sin(t * 2) * 0.07;
glowRef.current.scale.setScalar(1 + Math.sin(t * 1.5) * 0.08);
}
});

return (
<group position={data.pos} onClick={() => onSelect(locId)} onPointerOver={() => setHovered(true)} onPointerOut={() => setHovered(false)}>
{/* Glow sphere */}
<mesh ref={glowRef}>
<sphereGeometry args={[data.size * 2.5, 12, 12]} />
<meshBasicMaterial color={data.color} transparent opacity={0.12} />
</mesh>
{/* Main node */}
<mesh ref={meshRef}>
<sphereGeometry args={[data.size * (hovered ? 1.2 : 1), 16, 16]} />
<meshStandardMaterial color={data.color} emissive={data.emissive} emissiveIntensity={selected ? 0.8 : 0.4} roughness={0.3} metalness={0.6} />
</mesh>
{/* Danger ring */}
<mesh rotation={[Math.PI / 2, 0, 0]} position={[0, -0.35, 0]}>
<ringGeometry args={[data.size * 1.5, data.size * 1.8, 32]} />
<meshBasicMaterial color={dangerColor} transparent opacity={0.5} side={THREE.DoubleSide} />
</mesh>
{/* Player indicator */}
{hasPlayer && (
<mesh position={[0, data.size + 0.15, 0]}>
<sphereGeometry args={[0.06, 8, 8]} />
<meshBasicMaterial color={0xffffff} />
</mesh>
)}
{/* Label */}
<Html distanceFactor={6} position={[0, data.size + 0.3, 0]} style={{ pointerEvents: “none” }}>
<div style={{ fontFamily: “‘Cinzel’, serif”, fontSize: “7px”, color: hovered ? “#f0c040” : “#c8813a”, whiteSpace: “nowrap”, textShadow: “0 0 8px rgba(0,0,0,0.9)”, letterSpacing: “1px”, textTransform: “uppercase”, userSelect: “none” }}>
{WORLD_LOCATIONS.find(l => l.id === locId)?.short || locId}
</div>
</Html>
</group>
);
}

function Map3DScene({ mapDanger, players, selectedLoc, onSelectLoc }) {
const playersByLoc = {};
players.filter(p => !p.isDead && p.location).forEach(p => { playersByLoc[p.location] = true; });

return (
<>
<Stars radius={80} depth={50} count={2000} factor={3} saturation={0} fade speed={0.5} />
<ambientLight intensity={0.08} />
<pointLight position={[0, 3, 0]} intensity={0.8} color={0xf0a855} distance={12} />
<pointLight position={[-3, 1, -2]} intensity={0.3} color={0x4fc3f7} />
<pointLight position={[3, 1, 2]} intensity={0.3} color={0x9c27b0} />
<TerrainPlane />
<GridLines />
{/* Connection lines */}
{WORLD_LOCATIONS.map(loc => loc.connectedTo.map(toId => {
const toLoc = WORLD_LOCATIONS.find(l => l.id === toId);
if (!toLoc) return null;
const fromD = LOC_3D[loc.id], toD = LOC_3D[toId];
if (!fromD || !toD) return null;
return <ConnectionLine key={`${loc.id}-${toId}`} fromPos={fromD.pos} toPos={toD.pos} />;
}))}
{/* Location nodes */}
{WORLD_LOCATIONS.map(loc => {
const d3 = LOC_3D[loc.id];
if (!d3) return null;
return (
<LocationNode
key={loc.id}
locId={loc.id}
data={d3}
danger={mapDanger[loc.id] ?? loc.danger}
selected={selectedLoc === loc.id}
onSelect={onSelectLoc}
hasPlayer={!!playersByLoc[loc.id]}
/>
);
})}
<OrbitControls enablePan={false} minDistance={4} maxDistance={14} maxPolarAngle={Math.PI / 2.2} autoRotate autoRotateSpeed={0.3} />
</>
);
}

